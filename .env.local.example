# =====================================================================
# Recebimento Provisório - Anexo III — variáveis de ambiente
# Copie para .env.local e preencha. NUNCA commitar .env.local.
# =====================================================================

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co

# service_role (NUNCA expor no client; só uso server-side)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Segredo para assinar o cookie de sessão. Gere um valor aleatório longo:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=troque-por-um-valor-aleatorio-longo
